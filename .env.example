# ===========================================================================
# Single env file for the whole app. Copy to .env and fill in.
# Next.js, Prisma, and the setup scripts all read it. Never commit .env.
# ===========================================================================

# --- Database (Neon or any PostgreSQL) ---
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# --- Auth / crypto (generate real values) ---
# openssl rand -base64 48   -> JWT_SECRET
# openssl rand -base64 32   -> ENCRYPTION_KEY (must decode to 32 bytes)
# openssl rand -base64 32   -> BLIND_INDEX_KEY
JWT_SECRET="change-me"
ENCRYPTION_KEY="change-me-32-byte-base64=="
BLIND_INDEX_KEY="change-me-base64=="
SESSION_TTL_HOURS=12
# Production: COOKIE_SECURE=true (HTTPS). COOKIE_SAMESITE=lax works when the app
# is one origin; use "none" only if you split it across different sites.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Public URL of this app (email links). e.g. https://app.yourdomain.com
APP_URL="http://localhost:3000"
DPR_SLA_DAYS=30

# --- Email (optional; unset SMTP_HOST → emails print to server console) ---
# SMTP_HOST="smtp.example.com"
# SMTP_PORT=587
# SMTP_USER="apikey"
# SMTP_PASS="secret"
MAIL_FROM="Consent Manager <no-reply@consent.local>"

# --- Billing (optional; Razorpay) ---
# RAZORPAY_KEY_ID="rzp_test_xxx"
# RAZORPAY_KEY_SECRET="xxx"
# RAZORPAY_WEBHOOK_SECRET="xxx"
# RAZORPAY_PLAN_STARTER="plan_xxx"
# RAZORPAY_PLAN_GROWTH="plan_xxx"

# --- Cron (SLA reminder sweep endpoint) ---
# CRON_SECRET="a-long-random-string"

# --- Super-admin seed (optional) ---
# SUPERADMIN_EMAIL="super@yourdomain.com"
# SUPERADMIN_PASSWORD="a-strong-password"

# ===========================================================================
# Widget hosting (Cloudflare R2)
# ===========================================================================
# API origin baked into the widget. The API is in this app, so it's the app's
# public URL. MUST be public for the R2 widget to work on real customer sites.
WIDGET_API_BASE="http://localhost:3000"

# Install-page snippet URL. Unset in dev → local /widget.js. After deploy:widget:
# NEXT_PUBLIC_WIDGET_URL="https://pub-xxxxxxxx.r2.dev/widget.js"

# --- R2 deploy (npm run deploy:widget) ---
# R2_ACCOUNT_ID="..."
# R2_BUCKET="cookie-access"
# R2_PUBLIC_URL="https://pub-xxxxxxxx.r2.dev"
# R2_ACCESS_KEY_ID="..."
# R2_SECRET_ACCESS_KEY="..."
