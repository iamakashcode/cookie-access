{
  "name": "dpdp-consent-manager",
  "version": "0.1.0",
  "private": true,
  "description": "DPDP consent management SaaS — single Next.js app (public site + dashboard + API) plus the embeddable widget.",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "npm run build:widget && next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "build:widget": "node widget/build.mjs",
    "watch:widget": "node widget/build.mjs --watch",
    "deploy:widget": "node --env-file=.env scripts/deploy-widget.mjs",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev && npm run guards:apply",
    "prisma:deploy": "prisma migrate deploy && npm run guards:apply",
    "guards:apply": "tsx prisma/apply-guards.ts",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:studio": "prisma studio",
    "db:setup": "prisma migrate deploy && npm run guards:apply && npm run prisma:seed"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.7",
    "jsonwebtoken": "^9.0.2",
    "next": "^14.2.21",
    "nodemailer": "^9.0.3",
    "razorpay": "^2.9.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.5",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "aws4fetch": "^1.0.20",
    "esbuild": "^0.24.2",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
